NODE_ENV=development
PORT=4010
APP_URL=https://financeiro.lidera.app.br
FRONTEND_URL=https://financeiro.lidera.app.br,http://localhost:4011,http://localhost:3000

# ─── Banco de Dados (Supabase PostgreSQL) ────────────────────────────────────
# Transaction Pooler — runtime (NestJS / Prisma queries)
# IMPORTANTE: Use senha sem @ ou % para evitar problemas de URL encoding
DATABASE_URL="postgresql://postgres.SEU_PROJECT_REF:SENHA@aws-X-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session Pooler — migrações (Prisma Migrate)
DIRECT_URL="postgresql://postgres.SEU_PROJECT_REF:SENHA@aws-X-sa-east-1.pooler.supabase.com:5432/postgres"

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL="https://SEU_PROJECT_REF.supabase.co"
# Chave secreta (service_role) — NUNCA expor no frontend
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."

# ─── Auth (legado — mantido para compatibilidade) ────────────────────────────
JWT_SECRET=siafi-jwt-secret-troque-em-producao-256-bits
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=siafi-refresh-secret-troque-em-producao-256-bits
JWT_REFRESH_EXPIRES_IN=7d

# ─── Mercado Pago ─────────────────────────────────────────────────────────────
MP_ACCESS_TOKEN=APP_USR-...
MP_PUBLIC_KEY=APP_USR-...
MP_WEBHOOK_SECRET=sua_chave_webhook_mp

# ─── WhatsApp (Evolution API) ────────────────────────────────────────────────
WHATSAPP_API_URL=http://localhost:8080
WHATSAPP_API_KEY=sua_chave
WHATSAPP_INSTANCE=sua_instancia

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=seu@email.com
MAIL_PASS=sua_senha_app
MAIL_FROM_NAME=SIAFI

# ─── Redis (BullMQ — filas assíncronas) ───────────────────────────────────────
# Upstash Redis recomendado para produção (free tier disponível)
REDIS_HOST=redis-host.exemplo.com
REDIS_PORT=6379
REDIS_PASSWORD=senha_segura_aqui
REDIS_TLS=true                    # true em produção (Upstash), false em dev local

# ─── Evolution API (WhatsApp) — nomes alternativos ────────────────────────────
EVOLUTION_API_URL=https://evolution.lidera.app.br
EVOLUTION_API_KEY=chave_api_evolution
EVOLUTION_INSTANCE=lidera
WHATSAPP_SUPORTE=(65) 99999-9999  # exibido em mensagens de cobrança

# ─── SMTP padronizado (alias das vars MAIL_*) ─────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@lidera.com
SMTP_PASS=senha_de_app_gmail
SMTP_FROM="Lidera Financeira <noreply@lidera.com>"

# ─── BullBoard — painel de monitoramento de filas ─────────────────────────────
# Acesse: https://financeiro.lidera.app.br/admin/queues
# Autenticação: Bearer <JWT de usuário admin>

# ─── Debug (apenas dev) ───────────────────────────────────────────────────────
DEBUG_WHATSAPP=5565999999999      # número para testes via POST /api/debug/queue/test-whatsapp
